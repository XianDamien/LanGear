# --- Google Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_ID=gemini-3.1-flash-lite-preview
GEMINI_PROMPT_VERSION=v1
AI_FEEDBACK_PROVIDER=gemini

# --- Alibaba Cloud (OSS + ASR) ---
OSS_ACCESS_KEY_ID=your_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_BUCKET_NAME=your_bucket_name
# Optional legacy public-read base URL. Leave unset when using STS + signed URLs.
# OSS_PUBLIC_BASE_URL=https://your-bucket.oss-cn-shanghai.aliyuncs.com
OSS_REGION=cn-shanghai
# Required only for /api/v1/oss/sts-token
ALIYUN_ROLE_ARN=acs:ram::123456789012:role/your-oss-upload-role

# Aliyun ASR (FunASR or Paraformer)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# --- Database ---
DATABASE_URL=sqlite:///data/langear.db

# --- CORS ---
CORS_ORIGINS=http://localhost:3002
