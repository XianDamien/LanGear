{
  "name": "langear-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "sh -c 'vite --mode mock --host \"${HOST:-localhost}\" --port \"${PORT:-3002}\"'",
    "build": "vue-tsc -b && vite build",
    "build:mock": "vue-tsc -b && vite build --mode mock",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@vueuse/core": "^13.0.0",
    "ali-oss": "^6.23.0",
    "axios": "^1.7.0",
    "echarts": "^5.6.0",
    "element-plus": "^2.12.0",
    "lucide-vue-next": "^0.475.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.58.2",
    "@types/ali-oss": "^6.23.2",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.7",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.2.6",
    "vitest": "^4.1.1",
    "vue-tsc": "^2.2.0"
  }
}
